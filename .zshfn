#SYSTEM

function mise-clean {
  command mise-clean
}

function update-system {
  local OS_TYPE=$(uname -s)

  if [[ "${OS_TYPE}" == "Darwin" ]]; then
      brew update && brew upgrade;

      sheldon lock --update;
  elif [[ "${OS_TYPE}" == "Linux" ]]; then
      adg -y && adu -y;
      
      cargo install-update -a && sheldon lock --update;

      sheldon completions --shell zsh > ${ZSH_CACHE_DIR}/completions/_sheldon;
  else
      echo "Unsuported system!"
  fi

  bin-update; mise upgrade -y; mise install; claude-update;
}


# CLI AUTH

function auth-docker
{
  echo $(op read $DOCKER_AUTH_TOKEN) | docker login --username $(op read $DOCKER_USERNAME) --password-stdin
}

function auth-convex
{
  echo "{ \"accessToken\": \"$(op read $CONVEX_AUTH_TOKEN)\" }" > ~/.convex/config.json
}

function auth-convex-work
{
  echo "{ \"accessToken\": \"$(op read $CONVEX_WORK_AUTH_TOKEN)\" }" > ~/.convex/config.json
}


# DOCKER

function docker-connect-minikube
{
  eval $(minikube -p minikube docker-env)
}

# NODE/BUN

function pm
{
  local d="$PWD"
  
  # Traverse up the directory tree
  while true; do
    if [[ -f "$d/bun.lockb" ]] || [[ -f "$d/bun.lock" ]]; then
      command bun "$@"
      return
    elif [[ -f "$d/pnpm-lock.yaml" ]]; then
      command pnpm "$@"
      return
    elif [[ -f "$d/yarn.lock" ]]; then
      command yarn "$@"
      return
    elif [[ -f "$d/package-lock.json" ]]; then
      command npm "$@"
      return
    fi

    # If we reach root without finding a lockfile, break the loop
    [[ "$d" == "/" ]] && break
    
    # Move to parent directory
    d=${d:h}
  done

  # Fallback to pnpm if no lockfile is found anywhere in the tree
  command pnpm "$@"
}


# BEADS

function _bd-repo-slug
{
  local root=$1
  printf '%s-%s' "${root:t}" "$(printf '%s' "$root" | shasum | cut -c1-8)"
}

function _bd-beads-dir
{
  local root
  root=$(git rev-parse --show-toplevel 2>/dev/null)
  if [[ -n "$root" ]]; then
    printf '%s\n' "$HOME/.beads-data/$(_bd-repo-slug "$root")/.beads"
  else
    printf '%s\n' "$HOME/.beads-data/_global/.beads"
  fi
}

function _bd-init
{
  local target
  target=$(_bd-beads-dir)
  mkdir -p "${target:h}"

  BEADS_DIR="$target" command bd init "$@" || return $?
  bd-backup-init "$target"
}

function bd
{
  if [[ "$1" == "init" ]]; then
    shift
    _bd-init "$@"
    return $?
  fi

  BEADS_DIR="$(_bd-beads-dir)" command bd "$@"
}

# PUBLIC: callable standalone to fix projects that are DB-initialized
# but have no backup destination configured. Do NOT rename to _bd-*.
function bd-backup-init
{
  local target=${1:-$(_bd-beads-dir)} root backup_dest
  root=$(git rev-parse --show-toplevel 2>/dev/null)
  [[ -z "$root" ]] && return 0
  [[ -f "$target/dolt-backup.json" ]] && return 0

  if [[ -z "$BEADS_BACKUP_ROOT" ]]; then
    echo "bd-backup-init: BEADS_BACKUP_ROOT is not set (add to ~/.zprofile)" >&2
    return 1
  fi

  backup_dest="$BEADS_BACKUP_ROOT/$(_bd-repo-slug "$root")"
  mkdir -p "${backup_dest:h}"

  BEADS_DIR="$target" command bd backup init "$backup_dest" --quiet 2>/dev/null \
    && echo "bd: backup configured → $backup_dest"
}
