#!/usr/bin/env bash

# claude-update - Update Claude Code plugins and marketplaces

echo
echo "================================================================"
echo "================ UPDATING CLAUDE CODE =========================="
echo "================================================================"
echo

if ! command -v claude &>/dev/null; then
    echo "Claude Code CLI not found, skipping"
    exit 0
fi

IFS=',' read -ra config_roots <<< "${CLAUDE_CONFIG_ROOTS:-$HOME/.claude}"
for root in "${config_roots[@]}"; do
    echo "Updating marketplaces and plugins for ${root}..."
    CLAUDE_CONFIG_DIR="$root" claude plugin marketplace update 2>/dev/null && echo "  Done"
done

echo
echo "Updating skills..."
npx skills update -g 2>/dev/null && echo "Skills updated"
