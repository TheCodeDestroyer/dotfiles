#!/usr/bin/env bash

# claude-update - Update Claude Code plugins and marketplaces

echo
echo "================================================================"
echo "================ UPDATING CLAUDE CODE =========================="
echo "================================================================"
echo

if ! command -v claude &>/dev/null; then
    echo "Claude Code CLI not found, skipping"
    exit 0
fi

echo "Updating marketplaces and plugins..."
claude plugin marketplace update 2>/dev/null && echo "Marketplaces and plugins updated"

echo
echo "Updating skills..."
npx skills update -g 2>/dev/null && echo "Skills updated"
