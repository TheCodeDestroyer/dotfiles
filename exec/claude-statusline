#!/usr/bin/env bash
# ~/.claude/statusline.sh
# Fast local Claude Code status line with color-coded context, git info, and cost.
# Compatible with bash 3.2 (macOS default).

RESET="\033[0m"
BOLD="\033[1m"
DIM="\033[2m"
RED="\033[31m"
GREEN="\033[32m"
YELLOW="\033[33m"
BLUE="\033[34m"
CYAN="\033[36m"
BRIGHT_RED="\033[91m"
BRIGHT_GREEN="\033[92m"
BRIGHT_YELLOW="\033[93m"
MAGENTA="\033[35m"
BRIGHT_MAGENTA="\033[95m"

SEP="${DIM} | ${RESET}"

# ── Layout config ──
# Each segment has a line assignment. To rearrange, change the number.
#   segment    line
L_MODEL=1;    L_CONTEXT=1;  L_RATE=1;  L_PEAK=1
L_GIT=2
L_TASK=3

# Segment visibility thresholds
T_RATE=50

# Line accumulators (pipe-delimited, joined at render)
_L1="" _L2="" _L3=""

add() {
  local line="$1" value="$2"
  [ -z "$value" ] && return
  case "$line" in
    1) [ -n "$_L1" ] && _L1+="$SEP"; _L1+="$value" ;;
    2) [ -n "$_L2" ] && _L2+="$SEP"; _L2+="$value" ;;
    3) [ -n "$_L3" ] && _L3+="$SEP"; _L3+="$value" ;;
  esac
}

# ── Parse stdin JSON ──
{
  read -r model
  read -r used_pct
  read -r total_input
  read -r ctx_size
  read -r rate_5h_pct
  read -r rate_5h_resets
  read -r session_id
} < <(
  jq -r '
    ((.model.display_name // "Claude") | sub(" \\(.*$"; "")),
    (.context_window.used_percentage // ""),
    (((.context_window.current_usage.input_tokens // 0) + (.context_window.current_usage.cache_creation_input_tokens // 0) + (.context_window.current_usage.cache_read_input_tokens // 0)) | floor),
    ((.context_window.context_window_size // 0) | floor),
    (.rate_limits.five_hour.used_percentage // ""),
    (.rate_limits.five_hour.resets_at // ""),
    (.session_id // "")
  '
)

# ── Format helpers ──
format_tokens() {
  local val="$1" round="$2"
  if [ -z "$val" ] || [ "$val" = "0" ]; then echo "0"; return; fi
  if [ "$val" -ge 1000000 ]; then
    local whole=$(( val / 1000000 )) frac=$(( (val % 1000000) / 100000 ))
    if [ "$round" = "1" ] || [ "$frac" -eq 0 ]; then printf "%dM" "$whole"
    else printf "%d.%dM" "$whole" "$frac"; fi
  else
    local whole=$(( val / 1000 )) frac=$(( (val % 1000) / 100 ))
    if [ "$round" = "1" ] || [ "$frac" -eq 0 ]; then printf "%dk" "$whole"
    else printf "%d.%dk" "$whole" "$frac"; fi
  fi
}

# ── Build segments ──

# Model
add $L_MODEL "${BOLD}${CYAN}${model}${RESET}"

# Git
git_seg=""
git_dir=$(git -c gc.auto=0 rev-parse --git-dir 2>/dev/null)
if [ -n "$git_dir" ]; then
  branch=$(git -c gc.auto=0 branch --show-current 2>/dev/null)
  if [ -n "$branch" ]; then
    git_seg="${BLUE} ${branch}${RESET}"

    [ -f "$git_dir/commondir" ] && git_seg+=" ${BRIGHT_YELLOW}[worktree]${RESET}"

    diff_parts=""
    diff_stat=$(git -c gc.auto=0 diff --numstat HEAD 2>/dev/null)
    if [ -n "$diff_stat" ]; then
      added=0 removed=0
      while IFS=$'\t' read -r a r _; do
        [[ "$a" =~ ^[0-9]+$ ]] && added=$(( added + a ))
        [[ "$r" =~ ^[0-9]+$ ]] && removed=$(( removed + r ))
      done <<< "$diff_stat"
      if [ "$added" != "0" ] || [ "$removed" != "0" ]; then
        diff_parts="${BRIGHT_GREEN}+${added}${RESET},${RED}-${removed}${RESET}"
      fi
    fi

    untracked=$(git -c gc.auto=0 ls-files --others --exclude-standard 2>/dev/null | wc -l | tr -d ' ')
    staged_new=$(git -c gc.auto=0 diff --cached --name-only --diff-filter=A 2>/dev/null | wc -l | tr -d ' ')
    new_files=$(( untracked + staged_new ))
    new_str=""
    [ "$new_files" -gt 0 ] && new_str="${CYAN}?${new_files}${RESET}"

    if [ -n "$diff_parts" ] || [ -n "$new_str" ]; then
      git_seg+="  ("
      [ -n "$diff_parts" ] && git_seg+="$diff_parts"
      [ -n "$diff_parts" ] && [ -n "$new_str" ] && git_seg+="${DIM} | ${RESET}"
      [ -n "$new_str" ] && git_seg+="$new_str"
      git_seg+=")"
    fi
  fi
fi
add $L_GIT "$git_seg"

# Context
tokens_fmt=$(format_tokens "$total_input" "0")
ctx_fmt=$(format_tokens "$ctx_size" "1")
ctx_color="$BRIGHT_GREEN"
if [ -n "$used_pct" ]; then
  pct_int=$(printf "%.0f" "$used_pct" 2>/dev/null || echo 0)
  if   [ "$pct_int" -ge 85 ]; then ctx_color="$BRIGHT_RED"
  elif [ "$pct_int" -ge 70 ]; then ctx_color="$BRIGHT_YELLOW"
  elif [ "$pct_int" -ge 50 ]; then ctx_color="$YELLOW"
  elif [ "$pct_int" -ge 25 ]; then ctx_color="$GREEN"
  fi
  ctx_pct_str=$(printf "%g%%" "$used_pct")
else
  ctx_pct_str="0%"
fi
add $L_CONTEXT "${ctx_color}${tokens_fmt}/${ctx_fmt} (${ctx_pct_str})${RESET}"

# 5h rate limit (always show %; timer only at threshold)
rate_seg=""
if [ -n "$rate_5h_pct" ]; then
  rate_int=$(printf "%.0f" "$rate_5h_pct" 2>/dev/null || echo 0)
  if   [ "$rate_int" -ge 90 ]; then rate_color="$BRIGHT_RED"
  elif [ "$rate_int" -ge 75 ]; then rate_color="$RED"
  elif [ "$rate_int" -ge 50 ]; then rate_color="$BRIGHT_MAGENTA"
  else rate_color="$MAGENTA"
  fi
  rate_seg="${rate_color}5h: $(printf "%g%%" "$rate_5h_pct")"
  if [ "$rate_int" -ge "$T_RATE" ] && [ -n "$rate_5h_resets" ]; then
    remaining=$(( rate_5h_resets - $(date +%s) ))
    [ "$remaining" -lt 0 ] && remaining=0
    rem_h=$(( remaining / 3600 ))
    rem_m=$(( (remaining % 3600 + 30) / 60 ))
    [ "$rem_m" -ge 60 ] && rem_h=$(( rem_h + 1 )) && rem_m=0
    rate_seg+=" ($(printf "%d:%02d" "$rem_h" "$rem_m"))"
  fi
  rate_seg+="${RESET}"
fi
add $L_RATE "$rate_seg"

# Peak hours (weekdays 5:00-11:00 PT)
peak_seg=""
read pt_wd pt_h pt_m < <(TZ=America/Los_Angeles date '+%u %H %M')
pt_mins=$(( 10#$pt_h * 60 + 10#$pt_m ))
if [ "$pt_wd" -le 5 ] && [ "$pt_mins" -ge 300 ] && [ "$pt_mins" -lt 660 ]; then
  peak_seg="${BRIGHT_RED}PEAK${RESET}"
fi
add $L_PEAK "$peak_seg"

# Current task
task_seg=""
todos_dir="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/todos"
if [ -n "$session_id" ] && [ -d "$todos_dir" ]; then
  latest=$(ls -t "$todos_dir"/${session_id}-agent-*.json 2>/dev/null | head -1)
  if [ -n "$latest" ]; then
    task=$(jq -r '[.[] | select(.status == "in_progress")][0].activeForm // empty' "$latest" 2>/dev/null)
    [ -n "$task" ] && task_seg="${BOLD}${BRIGHT_YELLOW}${task}${RESET}"
  fi
fi
add $L_TASK "$task_seg"

# ── Render ──
[ -n "$_L1" ] && printf "%b\n" "$_L1"
[ -n "$_L2" ] && printf "%b\n" "$_L2"
[ -n "$_L3" ] && printf "%b\n" "$_L3"
exit 0
