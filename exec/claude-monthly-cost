#!/usr/bin/env python3
"""claude-monthly-cost — Aggregate Claude Code token usage & estimated cost across all sessions.

Usage:
  claude-monthly-cost              # current month
  claude-monthly-cost 2026-03      # specific month
  claude-monthly-cost --all        # all time
  claude-monthly-cost --daily      # daily breakdown for current month
  claude-monthly-cost --daily 2026-03  # daily breakdown for specific month

Data is cached in ~/.claude/usage-ledger.json so historical data survives
session cleanup (default 30 days). Live sessions are only scanned when
the requested period includes recent/current data.
"""

import json
import os
import sys
from collections import defaultdict
from datetime import datetime, timedelta
from pathlib import Path

# ── Pricing (per million tokens, USD) ──
# https://docs.anthropic.com/en/docs/about-claude/pricing
PRICING = {
    "claude-opus-4-6": {"input": 15.00, "output": 75.00, "cache_write": 18.75, "cache_read": 1.50},
    "claude-sonnet-4-6": {"input": 3.00, "output": 15.00, "cache_write": 3.75, "cache_read": 0.30},
    "claude-haiku-4-5-20251001": {"input": 0.80, "output": 4.00, "cache_write": 1.00, "cache_read": 0.08},
}

LEDGER_VERSION = 1


def parse_args():
    daily = False
    all_time = False
    month = None

    for arg in sys.argv[1:]:
        if arg == "--daily":
            daily = True
        elif arg == "--all":
            all_time = True
        elif arg in ("--help", "-h"):
            print(__doc__.strip())
            sys.exit(0)
        elif len(arg) == 7 and arg[:4].isdigit() and arg[4] == "-":
            month = arg
        else:
            print(f"Unknown argument: {arg}", file=sys.stderr)
            sys.exit(1)

    if not month and not all_time:
        month = datetime.now().strftime("%Y-%m")

    return daily, all_time, month


# ── Ledger: persistent daily aggregates ──

def ledger_path(claude_dir):
    return claude_dir / "usage-ledger.json"


def load_ledger(path):
    """Load ledger as dict keyed by (date, model) -> token counts."""
    if not path.exists():
        return {}, None
    try:
        with open(path) as f:
            data = json.load(f)
        if data.get("version") != LEDGER_VERSION:
            return {}, None
        last_scan = data.get("last_scan_date")
        entries = {}
        for row in data.get("daily", []):
            key = (row["date"], row["model"])
            entries[key] = {
                "input": row["input"],
                "output": row["output"],
                "cache_write": row["cache_write"],
                "cache_read": row["cache_read"],
                "msgs": row["msgs"],
            }
        return entries, last_scan
    except (json.JSONDecodeError, KeyError, OSError):
        return {}, None


def save_ledger(path, entries, scan_date):
    """Save aggregated daily data to ledger."""
    daily = []
    for (date, model), t in sorted(entries.items()):
        daily.append({
            "date": date,
            "model": model,
            "input": t["input"],
            "output": t["output"],
            "cache_write": t["cache_write"],
            "cache_read": t["cache_read"],
            "msgs": t["msgs"],
        })
    data = {
        "version": LEDGER_VERSION,
        "last_scan_date": scan_date,
        "daily": daily,
    }
    tmp = path.with_suffix(".tmp")
    with open(tmp, "w") as f:
        json.dump(data, f, indent=2)
    tmp.rename(path)


def needs_live_scan(month, all_time, last_scan):
    """Determine if we need to scan live JSONL files."""
    today = datetime.now().strftime("%Y-%m-%d")
    today_month = today[:7]

    # No ledger yet — must scan
    if last_scan is None:
        return True

    # --all or current month: scan if we haven't scanned today
    if all_time or month == today_month:
        return last_scan != today

    # Past month: ledger has it if we ever scanned after that month ended
    # e.g. asking for 2026-03, ledger last scanned 2026-04-01 or later
    try:
        year, mon = int(month[:4]), int(month[5:7])
        if mon == 12:
            first_of_next = f"{year + 1}-01-01"
        else:
            first_of_next = f"{year}-{mon + 1:02d}-01"
        return last_scan < first_of_next
    except (ValueError, IndexError):
        return True


# ── JSONL scanning ──

def process_jsonl(path, deduped):
    """Parse a JSONL file, keeping most complete entry per requestId."""
    try:
        with open(path) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    obj = json.loads(line)
                except json.JSONDecodeError:
                    continue
                msg = obj.get("message", {})
                usage = msg.get("usage")
                req_id = obj.get("requestId")
                if not usage or not req_id:
                    continue
                ts = obj.get("timestamp", "")
                date = ts.split("T")[0] if "T" in ts else ""
                entry = {
                    "model": msg.get("model", "unknown"),
                    "date": date,
                    "input": usage.get("input_tokens", 0),
                    "output": usage.get("output_tokens", 0),
                    "cache_write": usage.get("cache_creation_input_tokens", 0),
                    "cache_read": usage.get("cache_read_input_tokens", 0),
                }
                prev = deduped.get(req_id)
                if prev is None or entry["output"] > prev["output"]:
                    deduped[req_id] = entry
    except (OSError, UnicodeDecodeError):
        pass


def scan_live_sessions(projects_dir):
    """Scan all JSONL files and return daily aggregates."""
    jsonl_files = list(projects_dir.rglob("*.jsonl"))
    if not jsonl_files:
        return {}

    print(f"Scanning {len(jsonl_files)} session files...", file=sys.stderr)

    deduped = {}
    for i, path in enumerate(jsonl_files):
        process_jsonl(path, deduped)
        if (i + 1) % 200 == 0:
            print(f"  ...{i + 1}/{len(jsonl_files)}", file=sys.stderr)

    print(f"  {len(deduped)} unique API calls found.", file=sys.stderr)

    # Aggregate by (date, model)
    agg = defaultdict(lambda: {"input": 0, "output": 0, "cache_write": 0, "cache_read": 0, "msgs": 0})
    for entry in deduped.values():
        key = (entry["date"], entry["model"])
        a = agg[key]
        a["input"] += entry["input"]
        a["output"] += entry["output"]
        a["cache_write"] += entry["cache_write"]
        a["cache_read"] += entry["cache_read"]
        a["msgs"] += 1

    return dict(agg)


# ── Display ──

def compute_cost(model, tokens):
    p = PRICING.get(model)
    if p is None:
        return None
    return (
        tokens["input"] * p["input"]
        + tokens["output"] * p["output"]
        + tokens["cache_write"] * p["cache_write"]
        + tokens["cache_read"] * p["cache_read"]
    ) / 1_000_000


def fmt_tokens(n):
    if n >= 1_000_000_000:
        return f"{n / 1_000_000_000:.1f}B"
    if n >= 1_000_000:
        return f"{n / 1_000_000:.1f}M"
    if n >= 1_000:
        return f"{n / 1_000:.1f}k"
    return str(n)


def display(agg, daily, all_time, month):
    """Filter and display aggregated data."""
    # Filter
    if not all_time:
        agg = {k: v for k, v in agg.items() if k[0].startswith(month)}

    if not agg:
        period = "all time" if all_time else month
        print(f"\nNo usage data found for {period}.")
        return

    # Collapse to model-only keys if not daily
    if not daily:
        collapsed = defaultdict(lambda: {"input": 0, "output": 0, "cache_write": 0, "cache_read": 0, "msgs": 0})
        for (date, model), t in agg.items():
            key = ("", model)
            for field in ("input", "output", "cache_write", "cache_read", "msgs"):
                collapsed[key][field] += t[field]
        rows = sorted(collapsed.items())
    else:
        rows = sorted(agg.items())

    # Header
    if daily:
        hdr = f"\n{'Date':<12} {'Model':<28} {'Input':>10} {'Output':>10} {'Cache Wr':>10} {'Cache Rd':>10} {'Msgs':>6} {'Cost':>10}"
    else:
        hdr = f"\n{'Model':<28} {'Input':>10} {'Output':>10} {'Cache Wr':>10} {'Cache Rd':>10} {'Msgs':>6} {'Cost':>10}"
    sep = "-" * len(hdr.strip())

    print(hdr)
    print(sep)

    total_cost = 0
    unknown_models = set()
    totals = {"input": 0, "output": 0, "cache_write": 0, "cache_read": 0, "msgs": 0}

    for (date, model), t in rows:
        cost = compute_cost(model, t)
        cost_str = f"${cost:>8.2f}" if cost is not None else "  unknown"
        if cost is None:
            unknown_models.add(model)
            cost = 0
        total_cost += cost
        for k in totals:
            totals[k] += t[k]

        if daily:
            print(
                f"{date:<12} {model:<28} {fmt_tokens(t['input']):>10} {fmt_tokens(t['output']):>10} "
                f"{fmt_tokens(t['cache_write']):>10} {fmt_tokens(t['cache_read']):>10} {t['msgs']:>6} {cost_str}"
            )
        else:
            print(
                f"{model:<28} {fmt_tokens(t['input']):>10} {fmt_tokens(t['output']):>10} "
                f"{fmt_tokens(t['cache_write']):>10} {fmt_tokens(t['cache_read']):>10} {t['msgs']:>6} {cost_str}"
            )

    print(sep)
    label = "TOTAL"
    if daily:
        print(
            f"{label:<41} {fmt_tokens(totals['input']):>10} {fmt_tokens(totals['output']):>10} "
            f"{fmt_tokens(totals['cache_write']):>10} {fmt_tokens(totals['cache_read']):>10} {totals['msgs']:>6} ${total_cost:>8.2f}"
        )
    else:
        print(
            f"{label:<28} {fmt_tokens(totals['input']):>10} {fmt_tokens(totals['output']):>10} "
            f"{fmt_tokens(totals['cache_write']):>10} {fmt_tokens(totals['cache_read']):>10} {totals['msgs']:>6} ${total_cost:>8.2f}"
        )

    period = "All-time" if all_time else month
    print(f"\n  {period} estimated cost: ${total_cost:.2f}")
    print("  (Based on API pricing — actual subscription cost may differ)")
    if unknown_models:
        print(f"  Warning: {len(unknown_models)} unknown model(s) excluded from cost: {', '.join(sorted(unknown_models))}")
    print()


# ── Main ──

def main():
    daily, all_time, month = parse_args()

    claude_dir = Path(os.environ.get("CLAUDE_DIR", Path.home() / ".claude"))
    projects_dir = claude_dir / "projects"
    lpath = ledger_path(claude_dir)

    # Load cached data
    ledger, last_scan = load_ledger(lpath)

    if needs_live_scan(month, all_time, last_scan):
        if not projects_dir.is_dir():
            if not ledger:
                print(f"No Claude Code projects directory found at {projects_dir}", file=sys.stderr)
                sys.exit(1)
        else:
            live = scan_live_sessions(projects_dir)

            # Merge: live data overwrites ledger for any day it covers,
            # since live is computed from full JSONL with deduplication.
            # Ledger keeps days no longer in live (expired sessions).
            live_dates = {date for date, _ in live}
            merged = {k: v for k, v in ledger.items() if k[0] not in live_dates}
            merged.update(live)
            ledger = merged

            # Save updated ledger
            today = datetime.now().strftime("%Y-%m-%d")
            try:
                save_ledger(lpath, ledger, today)
                print(f"  Ledger updated ({len(ledger)} daily records).", file=sys.stderr)
            except OSError as e:
                print(f"  Warning: could not save ledger: {e}", file=sys.stderr)
    else:
        print("Using cached ledger (no live scan needed).", file=sys.stderr)

    display(ledger, daily, all_time, month)


if __name__ == "__main__":
    main()
