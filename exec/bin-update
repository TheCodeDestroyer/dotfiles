#!/usr/bin/env bash

#bin-update - A script that updates bin folder

echo
echo "================================================================"
echo "============== UPDATING BIN EXECUTABLES & CONFIGS =============="
echo "================================================================"
echo

cd ~/bin

BIN_LOCATION="$(pwd)"

if hash gpg2 2>/dev/null; then
    GPG_EXECUTABLE_PATH=`which gpg2`
else
    GPG_EXECUTABLE_PATH=`which gpg`
fi

GPG_EXECUTABLE_NAME=`basename $GPG_EXECUTABLE_PATH`
echo "NAME: $GPG_EXECUTABLE_NAME"

echo "Found GPG executable: $GPG_EXECUTABLE_NAME"

if [[ -z $GPG_EXECUTABLE_NAME ]]
then
    echo "GPG executable not found. Exiting..."
    exit 1
fi

echo "Updating repo..."
git pull --rebase

echo "Adding executable privilige to scripts..."
chmod +x ~/bin/exec/*

echo "Linking config files..."
ln -sf ~/bin/.zshrc ~/.zshrc && echo "Linked .zshrc"
ln -sf ~/bin/.zshenv ~/.zshenv && echo "Linked .zshenv"
ln -sf ~/bin/.zshfn ~/.zshfn && echo "Linked .zshfn"
[ ! -f ~/.npmrc ] && cp ~/bin/.npmrc.template ~/.npmrc && echo "Created .npmrc from template"
mkdir -p ~/.config/sheldon
ln -sf ~/bin/sheldon.toml ~/.config/sheldon/plugins.toml && echo "Linked sheldon.toml"
mkdir -p ~/.claude
ln -sf ~/bin/exec/claude-statusline ~/.claude/statusline.sh && echo "Linked claude-statusline"

echo "Generating .gitconfig from template..."
cp ~/bin/.gitconfig.template ~/.gitconfig

OS_NAME=$(uname -s)

if [[ $OS_NAME = "Darwin" ]]
then
    sed -i "" "s/{{GPG_EXECUTABLE}}/"$GPG_EXECUTABLE_NAME"/g" ~/.gitconfig && echo "GPG executable updated"
else
    sed -i "s/{{GPG_EXECUTABLE}}/"$GPG_EXECUTABLE_NAME"/g" ~/.gitconfig && echo "GPG executable updated: $GPG_EXECUTABLE_NAME"
fi
